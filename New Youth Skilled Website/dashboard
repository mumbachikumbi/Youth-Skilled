<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Youth Skilled</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
:root{
    --bg-dark:#0f2027;
    --bg-dark2:#203a43;
    --bg-dark3:#2c5364;
    --primary:linear-gradient(90deg,#00f5ff,#00ff88);
    --accent:#00ff88;
}

*{box-sizing:border-box;}
body{
    margin:0;
    font-family:'Poppins',sans-serif;
    background:linear-gradient(135deg,var(--bg-dark),var(--bg-dark2),var(--bg-dark3));
    color:white;
    overflow-x:hidden;
}

/* PARTICLES */
#particles{
    position:fixed;
    width:100%;
    height:100%;
    z-index:-1;
    overflow:hidden;
}
.particle{
    position:absolute;
    width:4px;
    height:4px;
    background:#00f5ff;
    border-radius:50%;
    opacity:0.5;
    animation:float 12s linear infinite;
}
@keyframes float{
    from{transform:translateY(100vh);}
    to{transform:translateY(-10vh);}
}

/* NAVBAR */
nav{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px 8%;
    position:fixed;
    width:100%;
    backdrop-filter:blur(10px);
    background:rgba(255,255,255,0.05);
    border-bottom:1px solid rgba(255,255,255,0.1);
    z-index:1000;
}
.logo{
    font-size:22px;
    font-weight:700;
    background:var(--primary);
    -webkit-background-clip:text;
    color:transparent;
}
.nav-links{
    display:flex;
    gap:25px;
    flex-wrap:wrap;
}
.nav-links a{
    text-decoration:none;
    color:white;
    font-weight:500;
    white-space:nowrap;
    position: relative;
    transition: all 0.3s ease;
}
/* Hover effect: lift + glow */
.nav-links a:hover{
    transform: translateY(-3px);
    color: #00ff88;
    text-shadow: 0 0 10px #00ff88, 0 0 15px #00f5ff;
}

/* HERO */
.hero{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    padding:0 10%;
}
.hero h1{
    font-size:55px;
    background:var(--primary);
    -webkit-background-clip:text;
    color:transparent;
}
.hero p{
    margin-top:20px;
    font-size:18px;
    opacity:0.8;
}
.btn{
    margin-top:30px;
    padding:15px 35px;
    border:none;
    border-radius:30px;
    background:var(--primary);
    color:black;
    font-weight:600;
    cursor:pointer;
    transition:0.3s;
}
.btn:hover{
    transform:scale(1.1);
}

/* SECTIONS */
section{
    padding:140px 10%;
    position:relative;
    box-shadow:inset 0 40px 80px rgba(0,0,0,0.25);
}
section:nth-of-type(even){
    background:rgba(0,0,0,0.15);
}
section:nth-of-type(odd){
    background:rgba(255,255,255,0.03);
}
section::before{
    content:"";
    position:absolute;
    top:0;
    left:10%;
    width:80%;
    height:1px;
    background:linear-gradient(to right,transparent,#00f5ff,transparent);
    opacity:0.4;
}

/* TITLES */
.section-title{
    font-size:34px;
    text-align:center;
    margin-bottom:60px;
    position:relative;
}
.section-title::after{
    content:"";
    width:60px;
    height:3px;
    background:var(--primary);
    display:block;
    margin:15px auto 0;
    border-radius:10px;
}

/* CARDS */
.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:30px;
}
.card{
    padding:30px;
    border-radius:20px;
    background:rgba(255,255,255,0.05);
    backdrop-filter:blur(10px);
    border:1px solid rgba(255,255,255,0.1);
    transition:0.4s;
    opacity:0;
    transform:translateY(40px);
    box-shadow:0 10px 30px rgba(0,0,0,0.3);
}
.card:hover{
    transform:translateY(-10px);
    background:rgba(255,255,255,0.1);
}
.card.show{
    opacity:1;
    transform:translateY(0);
}
.card h3{
    margin-bottom:15px;
}
.card p{
    opacity:0.85;
    line-height:1.6;
}

/* IMPACT METRICS */
.metrics{
    display:flex;
    justify-content:space-around;
    flex-wrap:wrap;
    gap:30px;
    text-align:center;
}
.metric{
    font-size:32px;
    font-weight:700;
}
.metric-label{
    font-size:16px;
    opacity:0.7;
    margin-top:5px;
}

/* FORM */
input,textarea{
    width:100%;
    padding:12px;
    margin-bottom:15px;
    border-radius:8px;
    border:none;
    font-family:'Poppins',sans-serif;
}
input:focus,textarea:focus{
    outline:none;
    box-shadow:0 0 10px #00f5ff;
}

/* FINAL CTA */
.final-cta{
    text-align:center;
    background:linear-gradient(135deg,#00f5ff,#00ff88);
    color:black;
    padding:80px 10%;
    border-radius:20px;
}
.final-cta h2{
    font-size:40px;
    margin-bottom:25px;
}
.final-cta .btn{
    background:black;
    color:white;
}

/* FOOTER */
footer{
    text-align:center;
    padding:60px 10%;
    background:rgba(0,0,0,0.3);
    border-top:1px solid rgba(255,255,255,0.1);
}
footer .footer-content{
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:15px;
}
footer .social-icons{
    display:flex;
    gap:20px;
}
footer .social-icons a{
    color:white;
    transition: all 0.3s ease;
}
footer .social-icons a:hover{
    color:#00ff88;
    transform: translateY(-3px);
    text-shadow:0 0 10px #00ff88,0 0 15px #00f5ff;
}

/* MOBILE */
@media(max-width:768px){
    .hero h1{font-size:40px;}
    .metrics{flex-direction:column;}
}
</style>
</head>
<body>

<div id="particles"></div>

<nav>
    <div class="logo">Youth Skilled</div>
    <div class="nav-links">
        <a href="#courses">Courses</a>
        <a href="#companies">Companies</a>
        <a href="#certificates">Certificates</a>
        <a href="#impact">Impact</a>
        <a href="#contact">Contact</a>
    </div>
</nav>

<div class="hero">
    <div>
        <h1>Empowering Future Skills</h1>
        <p>Youth Skilled connects young talent with industry-leading opportunities and certifications.</p>
        <button class="btn">Get Started</button>
    </div>
</div>

<!-- COURSES -->
<section id="courses">
    <h2 class="section-title">Our Courses</h2>
    <div class="cards">
        <div class="card">
            <h3>🌐 Web Development</h3>
            <p>Master frontend and backend technologies to build real-world applications.</p>
        </div>
        <div class="card">
            <h3>🤖 Artificial Intelligence</h3>
            <p>Learn machine learning, data science and AI engineering fundamentals.</p>
        </div>
        <div class="card">
            <h3>🔐 Cyber Security</h3>
            <p>Protect digital systems and master ethical hacking techniques.</p>
        </div>
        <div class="card">
            <h3>📈 Digital Marketing</h3>
            <p>Build brand growth strategies using SEO and paid advertising.</p>
        </div>
    </div>
</section>

<!-- CERTIFICATES -->
<section id="certificates">
    <h2 class="section-title">Certifications</h2>
    <div class="cards">
        <div class="card">
            <h3>Industry Recognised</h3>
            <p>Aligned with global technology standards.</p>
        </div>
        <div class="card">
            <h3>Globally Valid</h3>
            <p>Accepted by employers internationally.</p>
        </div>
        <div class="card">
            <h3>Government Approved</h3>
            <p>Structured to meet national education requirements.</p>
        </div>
    </div>
</section>

<!-- EMPLOYERS / CORPORATE SERVICES -->
<section id="companies">
    <h2 class="section-title">Corporate Services</h2>
    <div class="cards">
        <div class="card">
            <h3>🏢 Employee Training</h3>
            <p>Structured training programs to upskill your workforce quickly.</p>
        </div>
        <div class="card">
            <h3>💼 Talent Pipeline</h3>
            <p>Access verified, job-ready youth for your hiring needs.</p>
        </div>
        <div class="card">
            <h3>🎯 Custom Cohorts</h3>
            <p>Design bespoke programs for your company or NGO with verifiable outcomes.</p>
        </div>
    </div>
</section>

<!-- IMPACT METRICS -->
<section id="impact">
    <h2 class="section-title">Our Impact</h2>
    <div class="metrics">
        <div>
            <div class="metric" data-target="15000">0</div>
            <div class="metric-label">Students Trained</div>
        </div>
        <div>
            <div class="metric" data-target="120">0</div>
            <div class="metric-label">Companies Engaged</div>
        </div>
        <div>
            <div class="metric" data-target="5000">0</div>
            <div class="metric-label">Certificates Issued</div>
        </div>
        <div>
            <div class="metric" data-target="10">0</div>
            <div class="metric-label">Grant-Funded Cohorts</div>
        </div>
    </div>
</section>

<!-- CONTACT -->
<section id="contact">
    <h2 class="section-title">Contact Us</h2>
    <div class="cards">
        <div class="card">
            <form>
                <input type="text" placeholder="Your Name" required>
                <input type="email" placeholder="Your Email" required>
                <textarea rows="4" placeholder="Your Message" required></textarea>
                <button type="submit" class="btn">Send Message</button>
            </form>
        </div>
    </div>
</section>

<!-- FINAL CTA -->
<section class="final-cta">
    <h2>Ready to Build Your Future?</h2>
    <button class="btn">Apply Now</button>
</section>

<!-- FOOTER WITH SOCIAL ICONS -->
<footer>
  <div class="footer-content">
    © 2026 Youth Skilled. All Rights Reserved.
    <div class="social-icons">
      <a href="https://facebook.com" target="_blank" aria-label="Facebook">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.522-4.478-10-10-10S2 6.478 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898v-2.891h2.54V9.845c0-2.507 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.464h-1.26c-1.243 0-1.63.772-1.63 1.562v1.875h2.773l-.443 2.891h-2.33v6.987C18.343 21.128 22 16.991 22 12z"/></svg>
      </a>
      <a href="https://twitter.com" target="_blank" aria-label="Twitter">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557a9.83 9.83 0 0 1-2.828.775A4.932 4.932 0 0 0 23.337 3.1a9.864 9.864 0 0 1-3.127 1.195 4.918 4.918 0 0 0-8.384 4.482A13.95 13.95 0 0 1 1.671 3.149a4.918 4.918 0 0 0 1.523 6.574 4.903 4.903 0 0 1-2.229-.616v.062a4.918 4.918 0 0 0 3.946 4.827 4.902 4.902 0 0 1-2.224.084 4.918 4.918 0 0 0 4.593 3.417 9.867 9.867 0 0 1-6.102 2.104c-.396 0-.788-.023-1.177-.069a13.945 13.945 0 0 0 7.557 2.212c9.054 0 14.002-7.496 14.002-13.986 0-.213-.004-.425-.014-.637A10.012 10.012 0 0 0 24 4.557z"/></svg>
      </a>
      <a href="https://linkedin.com" target="_blank" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5zM.5 8h4v16h-4V8zm7.5 0h3.7v2.1h.1c.5-.9 1.7-1.9 3.5-1.9 3.7 0 4.4 2.4 4.4 5.5V24h-4v-8c0-1.9-.04-4.4-2.7-4.4-2.7 0-3.1 2.1-3.1 4.3V24h-4V8z"/></svg>
      </a>
    </div>
  </div>
</footer>

<script>
// Scroll reveal
const observer=new IntersectionObserver(entries=>{
    entries.forEach(entry=>{
        if(entry.isIntersecting){
            entry.target.classList.add("show");
        }
    });
},{threshold:0.2});
document.querySelectorAll(".card").forEach(card=>{
    observer.observe(card);
});

// Particles
const particlesContainer=document.getElementById("particles");
for(let i=0;i<50;i++){
    const particle=document.createElement("div");
    particle.classList.add("particle");
    particle.style.left=Math.random()*100+"%";
    particle.style.animationDuration=(6+Math.random()*8)+"s";
    particle.style.opacity=Math.random();
    particlesContainer.appendChild(particle);
}

// Animated Metrics
const metrics=document.querySelectorAll('.metric');
metrics.forEach(metric=>{
    const updateCount=()=>{
        const target=+metric.getAttribute('data-target');
        let count=+metric.innerText;
        const increment=Math.ceil(target/200);
        if(count<target){
            metric.innerText=count+increment;
            setTimeout(updateCount,20);
        } else {
            metric.innerText=target;
        }
    };
    const observerMetric=new IntersectionObserver(entries=>{
        if(entries[0].isIntersecting){
            updateCount();
            observerMetric.disconnect();
        }
    },{threshold:0.5});
    observerMetric.observe(metric);
});
</script>

</body>
</html>